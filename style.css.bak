/* ============================================
   BIVACCHI APP - DARK THEME (MountPro Style)
   Color Palette: Zinc + Orange
   ============================================ */

/* CSS Variables */
:root {
    --bg-primary: #09090b;      /* zinc-950 */
    --bg-secondary: #18181b;    /* zinc-900 */
    --bg-tertiary: #27272a;     /* zinc-800 */
    --bg-hover: #3f3f46;        /* zinc-700 */
    --border-color: #3f3f46;    /* zinc-700 */
    --border-subtle: #27272a;   /* zinc-800 */
    
    --text-primary: #fafafa;    /* zinc-50 */
    --text-secondary: #a1a1aa;  /* zinc-400 */
    --text-muted: #71717a;      /* zinc-500 */
    
    --accent: #ea580c;          /* orange-600 */
    --accent-hover: #c2410c;    /* orange-700 */
    --accent-light: rgba(234, 88, 12, 0.2);
    
    --success: #22c55e;         /* green-500 */
    --warning: #f59e0b;         /* amber-500 */
    --danger: #ef4444;          /* red-500 */
    --info: #3b82f6;            /* blue-500 */
    
    --radius-sm: 8px;
    --radius-md: 12px;
    --radius-lg: 16px;
    --radius-xl: 24px;
    
    --shadow: 0 4px 20px rgba(0, 0, 0, 0.4);
    --shadow-lg: 0 8px 32px rgba(0, 0, 0, 0.5);
}

/* Google Font Inter */
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');

* {
    box-sizing: border-box;
}

html {
    height: 100%;
}

body {
    margin: 0;
    padding: 0;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    background-color: var(--bg-primary);
    color: var(--text-primary);
    height: 100%;
    display: flex;
    flex-direction: column;
    line-height: 1.5;
}

/* ============================================
   PWA Connection Banners
   ============================================ */
.connection-banner {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    padding: 12px 20px;
    color: white;
    text-align: center;
    font-weight: 500;
    z-index: 9999;
    box-shadow: var(--shadow);
    animation: slideDown 0.3s ease-out;
    backdrop-filter: blur(10px);
}

.connection-banner.online {
    background: linear-gradient(135deg, var(--success), #16a34a);
}

.connection-banner.offline {
    background: linear-gradient(135deg, var(--danger), #dc2626);
}

.connection-banner.syncing {
    background: linear-gradient(135deg, var(--warning), #d97706);
}

.connection-banner.fade-out {
    animation: slideUp 0.5s ease-out forwards;
}

.update-banner {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    padding: 12px 20px;
    background: linear-gradient(135deg, #8b5cf6, #7c3aed);
    color: white;
    text-align: center;
    font-weight: 500;
    z-index: 9999;
    box-shadow: var(--shadow);
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 15px;
}

.update-banner button {
    padding: 6px 15px;
    border: none;
    border-radius: var(--radius-sm);
    cursor: pointer;
    font-weight: 500;
    transition: all 0.2s;
}

.update-banner button:first-of-type {
    background: white;
    color: #7c3aed;
}

.update-banner button:last-of-type {
    background: transparent;
    color: white;
    font-size: 1.2em;
}

@keyframes slideDown {
    from { transform: translateY(-100%); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
}

@keyframes slideUp {
    from { transform: translateY(0); opacity: 1; }
    to { transform: translateY(-100%); opacity: 0; }
}

/* ============================================
   Main Layout
   ============================================ */
.app-container {
    padding: 16px;
    flex: 1;
    display: flex;
    flex-direction: column;
    min-height: 0;
}

.main-content {
    max-width: 1800px;
    margin: 0 auto;
    width: 100%;
    background: var(--bg-secondary);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-subtle);
    box-shadow: var(--shadow);
    display: flex;
    flex-direction: column;
    padding: 20px;
    flex: 1;
    min-height: 0;
}

/* ============================================
   Header
   ============================================ */
header {
    border-bottom: 1px solid var(--border-subtle);
    padding-bottom: 16px;
    margin-bottom: 16px;
}

header h2 {
    margin: 0 0 12px 0;
    color: var(--text-primary);
    font-weight: 700;
    font-size: 1.5em;
    letter-spacing: -0.02em;
}

.header-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
}

.header-top h2 {
    margin: 0;
    flex: 1;
}

#auth-area {
    display: flex;
    gap: 10px;
    align-items: center;
}

.user-name {
    padding: 10px 16px;
    color: var(--text-primary);
    font-weight: 500;
    background: var(--bg-tertiary);
    border-radius: var(--radius-md);
}

.auth-btn {
    padding: 10px 20px;
    background: var(--accent);
    color: white;
    border: none;
    border-radius: var(--radius-md);
    cursor: pointer;
    font-size: 0.9em;
    font-weight: 500;
    transition: all 0.2s;
}

.auth-btn:hover {
    background: var(--accent-hover);
    transform: translateY(-1px);
}

.logout-btn {
    background: var(--danger) !important;
}

.logout-btn:hover {
    background: #dc2626 !important;
}

/* ============================================
   Form Elements
   ============================================ */
.form-input, input[type="text"], input[type="email"], input[type="password"], textarea {
    width: 100%;
    padding: 12px 16px;
    margin-bottom: 12px;
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    font-size: 1em;
    background: var(--bg-tertiary);
    color: var(--text-primary);
    transition: all 0.2s;
}

.form-input:focus, input:focus, textarea:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-light);
}

.form-input::placeholder, input::placeholder, textarea::placeholder {
    color: var(--text-muted);
}

.form-btn {
    width: 100%;
    padding: 12px 16px;
    background: var(--accent);
    color: white;
    border: none;
    border-radius: var(--radius-md);
    cursor: pointer;
    font-size: 1em;
    font-weight: 600;
    transition: all 0.2s;
}

.form-btn:hover {
    background: var(--accent-hover);
    transform: translateY(-1px);
}

.form-btn:active {
    transform: translateY(0);
}

.form-divider {
    text-align: center;
    margin-top: 16px;
    color: var(--text-secondary);
}

.form-divider a {
    color: var(--accent);
    text-decoration: none;
    cursor: pointer;
    font-weight: 500;
}

.form-divider a:hover {
    text-decoration: underline;
}

.form-error {
    color: var(--danger);
    margin-bottom: 12px;
    font-size: 0.9em;
}

.small-btn {
    padding: 6px 14px !important;
    font-size: 0.85em !important;
    display: inline-block;
    width: auto;
    margin-left: 10px;
}

.small-text {
    font-size: 0.9em;
    color: var(--text-secondary);
    margin: 10px 0;
}

/* ============================================
   Search Input
   ============================================ */
#search-input {
    width: 100%;
    padding: 14px 18px;
    margin-top: 12px;
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    font-size: 1em;
    background: var(--bg-tertiary);
    color: var(--text-primary);
    transition: all 0.2s;
}

#search-input:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-light);
}

#search-input::placeholder {
    color: var(--text-muted);
}

/* ============================================
   Favorites List
   ============================================ */
.favorites-list {
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
    padding: 12px;
    margin: 12px 0;
    max-height: 200px;
    overflow-y: auto;
    background: var(--bg-tertiary);
}

.favorite-item {
    padding: 10px 12px;
    border-bottom: 1px solid var(--border-subtle);
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-radius: var(--radius-sm);
    transition: background 0.2s;
}

.favorite-item:hover {
    background: var(--bg-hover);
}

.favorite-item:last-child {
    border-bottom: none;
}

.favorite-item-name {
    flex: 1;
    color: var(--text-primary);
}

.heart-btn {
    background: none;
    border: none;
    font-size: 1.5em;
    cursor: pointer;
    padding: 5px;
    transition: transform 0.2s;
}

.heart-btn:hover {
    transform: scale(1.2);
}

/* ============================================
   Select / Dropdown
   ============================================ */
select {
    width: 100%;
    padding: 10px 14px;
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    font-size: 1em;
    background: var(--bg-tertiary);
    color: var(--text-primary);
    cursor: pointer;
    transition: all 0.2s;
}

select:focus {
    outline: none;
    border-color: var(--accent);
}

select option {
    background: var(--bg-secondary);
    color: var(--text-primary);
}

/* ============================================
   Filters Section
   ============================================ */
.filters {
    display: flex;
    gap: 20px;
    margin-bottom: 16px;
    flex-wrap: wrap;
    padding: 16px;
    background: var(--bg-tertiary);
    border-radius: var(--radius-md);
    border: 1px solid var(--border-subtle);
}

.view-buttons {
    display: none;
    gap: 10px;
}

.view-buttons button {
    padding: 10px 16px;
    border: 1px solid var(--border-color);
    background: var(--bg-tertiary);
    color: var(--text-primary);
    cursor: pointer;
    border-radius: var(--radius-md);
    transition: all 0.2s;
}

.view-buttons button.active {
    background: var(--accent);
    color: white;
    border-color: var(--accent);
}

.filter-group {
    flex: 0 1 auto;
    min-width: 150px;
    max-width: 280px;
}

.filter-group label {
    font-size: 0.85em;
    font-weight: 600;
    display: block;
    margin-bottom: 8px;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
}

/* noUiSlider Dark Theme */
.noUi-target {
    background: var(--bg-tertiary);
    border: 1px solid var(--border-color);
    box-shadow: none;
}

.noUi-connect {
    background: var(--accent);
}

.noUi-horizontal {
    height: 8px;
}

.noUi-horizontal .noUi-handle {
    width: 20px;
    height: 20px;
    right: -10px;
    top: -6px;
    border-radius: 50%;
    border: 2px solid var(--accent);
    background: var(--bg-secondary);
    box-shadow: 0 2px 8px rgba(0,0,0,0.3);
    cursor: grab;
}

.noUi-horizontal .noUi-handle:before,
.noUi-horizontal .noUi-handle:after {
    display: none;
}

.noUi-horizontal .noUi-handle:active {
    cursor: grabbing;
}

/* ============================================
   Content Wrapper (List + Map)
   ============================================ */
.content-wrapper {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 20px;
    height: 70vh;
    min-height: 520px;
}

/* ============================================
   List Container
   ============================================ */
.list-container {
    position: relative;
    width: 100%;
    overflow-y: auto;
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    padding: 8px;
    background: var(--bg-secondary);
    box-shadow: var(--shadow);
    height: 100%;
}

/* Custom Scrollbar */
.list-container::-webkit-scrollbar {
    width: 8px;
}

.list-container::-webkit-scrollbar-track {
    background: var(--bg-tertiary);
    border-radius: 4px;
}

.list-container::-webkit-scrollbar-thumb {
    background: var(--bg-hover);
    border-radius: 4px;
}

.list-container::-webkit-scrollbar-thumb:hover {
    background: var(--text-muted);
}

.placeholder-text {
    text-align: center;
    color: var(--text-muted);
    padding: 40px 20px;
    font-size: 1.1em;
}

/* ============================================
   Bivacco Item Card
   ============================================ */
.bivacco-item {
    padding: 16px;
    margin-bottom: 8px;
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
    background: var(--bg-tertiary);
    cursor: pointer;
    transition: all 0.2s;
}

.bivacco-item:hover {
    background: var(--bg-hover);
    border-color: var(--accent);
    transform: translateX(4px);
}

.bivacco-item:last-child {
    margin-bottom: 0;
}

.bivacco-item h4 {
    margin: 0 0 8px 0;
    color: var(--text-primary);
    font-weight: 600;
    font-size: 1.05em;
}

.bivacco-item p {
    margin: 0;
    font-size: 0.9em;
    color: var(--text-secondary);
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
}

.bivacco-item .temp-badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 2px 8px;
    background: var(--accent-light);
    color: var(--accent);
    border-radius: var(--radius-sm);
    font-weight: 500;
}

.bivacco-item .snow-badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 2px 8px;
    background: rgba(59, 130, 246, 0.2);
    color: var(--info);
    border-radius: var(--radius-sm);
    font-weight: 500;
}

/* Lazy loading list - load more button */
.load-more-btn {
    width: 100%;
    padding: 12px;
    margin-top: 8px;
    background: var(--accent);
    color: var(--text-primary);
    border: none;
    border-radius: var(--radius-md);
    cursor: pointer;
    font-size: 14px;
    font-weight: 500;
    transition: background 0.2s;
}

.load-more-btn:hover {
    background: var(--accent-hover);
}

.list-counter {
    padding: 8px 12px;
    background: var(--bg-tertiary);
    color: var(--text-secondary);
    border-radius: var(--radius-sm);
    font-size: 12px;
    text-align: center;
    margin-bottom: 8px;
}

/* ========== DATA STATUS STYLES ========== */
/* Dati in caricamento */
.data-loading {
    color: var(--accent);
    animation: pulse 1.5s ease-in-out infinite;
}

@keyframes pulse {
    0%, 100% { opacity: 0.4; }
    50% { opacity: 1; }
}

/* Dati non disponibili */
.data-unavailable {
    color: var(--text-secondary);
    opacity: 0.6;
}

/* Dati stale (vecchi) */
.data-stale {
    color: var(--warning, #f59e0b);
    opacity: 0.8;
}

/* ========== PROGRESS INDICATOR ========== */
.progress-bar-container {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--bg-tertiary);
    z-index: 9999;
    display: none;
}

.progress-bar-container.active {
    display: block;
}

.progress-bar {
    height: 100%;
    background: var(--accent);
    transition: width 0.3s ease;
    width: 0%;
}

.progress-label {
    position: fixed;
    top: 8px;
    right: 12px;
    background: var(--bg-secondary);
    color: var(--text-secondary);
    padding: 4px 8px;
    border-radius: var(--radius-sm);
    font-size: 11px;
    z-index: 9999;
    display: none;
}

.progress-label.active {
    display: block;
}

/* MarkerCluster custom styling for dark theme */
.marker-cluster-small {
    background-color: rgba(234, 88, 12, 0.6);
}
.marker-cluster-small div {
    background-color: rgba(234, 88, 12, 0.9);
}

.marker-cluster-medium {
    background-color: rgba(234, 88, 12, 0.7);
}
.marker-cluster-medium div {
    background-color: rgba(234, 88, 12, 1);
}

.marker-cluster-large {
    background-color: rgba(194, 65, 12, 0.8);
}
.marker-cluster-large div {
    background-color: rgba(194, 65, 12, 1);
}

.marker-cluster {
    background-clip: padding-box;
    border-radius: 50%;
}
.marker-cluster div {
    width: 30px;
    height: 30px;
    margin-left: 5px;
    margin-top: 5px;
    text-align: center;
    border-radius: 50%;
    font: 12px Inter, sans-serif;
    color: white;
    font-weight: 600;
    display: flex;
    align-items: center;
    justify-content: center;
}

.marker-cluster span {
    line-height: 1;
}

/* ============================================
   Map Container
   ============================================ */
.map-container {
    position: relative;
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    height: 100%;
    width: 100%;
    overflow: hidden;
}

/* Dark Map Tiles Override */
.leaflet-tile-pane {
    filter: brightness(0.85) contrast(1.1) saturate(0.9);
}

.leaflet-control-zoom a {
    background: var(--bg-secondary) !important;
    color: var(--text-primary) !important;
    border-color: var(--border-color) !important;
}

.leaflet-control-zoom a:hover {
    background: var(--bg-tertiary) !important;
}

.leaflet-control-attribution {
    background: rgba(24, 24, 27, 0.8) !important;
    color: var(--text-muted) !important;
}

.leaflet-control-attribution a {
    color: var(--text-secondary) !important;
}

.leaflet-popup-content-wrapper {
    background: var(--bg-secondary);
    color: var(--text-primary);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-lg);
}

.leaflet-popup-tip {
    background: var(--bg-secondary);
}

.leaflet-popup-close-button {
    color: var(--text-secondary) !important;
}

.leaflet-popup-close-button:hover {
    color: var(--text-primary) !important;
}

/* ============================================
   Modals
   ============================================ */
.modal {
    position: fixed;
    z-index: 2000;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(4px);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s, visibility 0.3s;
}

.modal[style*="display: flex;"] {
    opacity: 1;
    visibility: visible;
}

.modal-content {
    background: var(--bg-secondary);
    padding: 28px;
    border-radius: var(--radius-xl);
    border: 1px solid var(--border-subtle);
    width: 90%;
    max-width: 500px;
    position: relative;
    box-shadow: var(--shadow-lg);
    transform: scale(0.95) translateY(20px);
    transition: transform 0.3s;
}

.modal[style*="display: flex;"] .modal-content {
    transform: scale(1) translateY(0);
}

.modal-content h3, .modal-content h4 {
    color: var(--text-primary);
    margin-top: 0;
}

.detail-modal-content {
    max-width: 600px;
    max-height: 85vh;
    overflow-y: auto;
}

.close-btn {
    position: absolute;
    right: 18px;
    top: 18px;
    font-size: 28px;
    font-weight: bold;
    color: var(--text-muted);
    cursor: pointer;
    transition: color 0.2s;
    line-height: 1;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
}

.close-btn:hover {
    color: var(--text-primary);
    background: var(--bg-tertiary);
}

/* ============================================
   Navigation Buttons
   ============================================ */
.nav-btn, .osm-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    text-align: center;
    background: var(--accent);
    color: white !important;
    padding: 12px 20px;
    text-decoration: none;
    border-radius: var(--radius-md);
    margin-top: 16px;
    margin-right: 10px;
    transition: all 0.2s;
    border: none;
    font-size: 0.95em;
    font-weight: 500;
}

.nav-btn:hover {
    background: var(--accent-hover);
    transform: translateY(-1px);
}

.osm-btn {
    background: var(--info);
}

.osm-btn:hover {
    background: #2563eb;
}

/* ============================================
   Comments Section
   ============================================ */
.comment-item {
    padding: 14px;
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
    margin-bottom: 10px;
    background: var(--bg-tertiary);
}

.comment-header {
    font-size: 0.85em;
    color: var(--text-muted);
    margin-bottom: 6px;
    display: flex;
    justify-content: space-between;
}

.comment-header strong {
    color: var(--accent);
}

.comment-item p {
    margin: 6px 0 0 0;
    font-size: 0.95em;
    line-height: 1.5;
    color: var(--text-primary);
}

.comment-form {
    margin-top: 16px;
    padding-top: 16px;
    border-top: 1px solid var(--border-subtle);
}

.comment-form textarea {
    resize: vertical;
    font-family: inherit;
    min-height: 80px;
}

/* ============================================
   Error State
   ============================================ */
.error {
    color: var(--danger);
    font-weight: 600;
    padding: 12px;
    background: rgba(239, 68, 68, 0.1);
    border-radius: var(--radius-md);
    border: 1px solid rgba(239, 68, 68, 0.3);
}

/* ============================================
   Mobile Filter Button
   ============================================ */
.mobile-filter-btn {
    display: none;
    width: 100%;
    padding: 14px;
    margin-bottom: 12px;
    background: var(--accent);
    color: white;
    border: none;
    border-radius: var(--radius-md);
    font-size: 1em;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
}

.mobile-filter-btn:hover {
    background: var(--accent-hover);
}

/* ============================================
   Mobile View Toggle
   ============================================ */
.mobile-view-toggle {
    display: none;
}

/* ============================================
   Responsive - Mobile
   ============================================ */
@media (max-width: 1024px) {
    .app-container {
        padding: 12px;
    }

    .main-content {
        padding: 14px;
        border-radius: var(--radius-md);
    }

    header h2 {
        font-size: 1.2em;
    }

    .mobile-filter-btn {
        display: block !important;
    }

    #desktop-filters {
        display: none !important;
    }

    .mobile-view-toggle {
        display: flex !important;
        position: fixed;
        bottom: 20px;
        left: 50%;
        transform: translateX(-50%);
        background: var(--bg-secondary);
        border: 1px solid var(--border-color);
        border-radius: 30px;
        box-shadow: var(--shadow-lg);
        padding: 6px;
        gap: 6px;
        z-index: 1000;
    }

    .mobile-view-toggle button {
        padding: 12px 24px;
        border: none;
        background: transparent;
        color: var(--text-secondary);
        cursor: pointer;
        border-radius: 24px;
        font-size: 0.95em;
        font-weight: 500;
        transition: all 0.2s;
    }

    .mobile-view-toggle button.active {
        background: var(--accent);
        color: white;
    }

    .filters-modal-content {
        max-height: 90vh;
        overflow-y: auto;
    }

    .mobile-filters-content {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .mobile-filters-content .filter-group {
        width: 100%;
        max-width: 100%;
    }

    .detail-modal-content {
        max-height: 85vh;
        overflow-y: auto;
        max-width: 95%;
    }

    .content-wrapper {
        display: flex;
        flex-direction: column;
        position: static;
        height: auto;
        flex: 1;
        min-height: 0;
        margin-bottom: 80px;
    }

    .list-container {
        position: relative;
        width: 100%;
        flex: 1;
        height: auto;
        min-height: 300px;
    }

    .map-container {
        position: relative;
        width: 100%;
        height: 60vh;
        min-height: 320px;
        display: none;
    }
}

/* ============================================
   Utility Classes
   ============================================ */
.text-accent { color: var(--accent); }
.text-success { color: var(--success); }
.text-warning { color: var(--warning); }
.text-danger { color: var(--danger); }
.text-info { color: var(--info); }
.text-muted { color: var(--text-muted); }

.bg-accent { background: var(--accent); }
.bg-success { background: var(--success); }
.bg-warning { background: var(--warning); }
.bg-danger { background: var(--danger); }

.mt-2 { margin-top: 8px; }
.mt-4 { margin-top: 16px; }
.mb-2 { margin-bottom: 8px; }
.mb-4 { margin-bottom: 16px; }
.p-2 { padding: 8px; }
.p-4 { padding: 16px; }

.font-bold { font-weight: 700; }
.font-semibold { font-weight: 600; }
.uppercase { text-transform: uppercase; }
.tracking-wide { letter-spacing: 0.05em; }

/* ============================================
   Stat Boxes (for detail view)
   ============================================ */
.stat-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
    margin: 16px 0;
}

.stat-box {
    background: var(--bg-tertiary);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
    padding: 14px;
    text-align: center;
}

.stat-box .stat-label {
    font-size: 0.75em;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
    margin-bottom: 4px;
}

.stat-box .stat-value {
    font-size: 1.4em;
    font-weight: 700;
    color: var(--text-primary);
}

.stat-box .stat-value.accent {
    color: var(--accent);
}

/* ============================================
   Tags/Badges
   ============================================ */
.badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 4px 10px;
    border-radius: var(--radius-sm);
    font-size: 0.8em;
    font-weight: 500;
}

.badge-orange {
    background: var(--accent-light);
    color: var(--accent);
}

.badge-blue {
    background: rgba(59, 130, 246, 0.2);
    color: var(--info);
}

.badge-green {
    background: rgba(34, 197, 94, 0.2);
    color: var(--success);
}

.badge-red {
    background: rgba(239, 68, 68, 0.2);
    color: var(--danger);
}

/* ============================================
   Loading Spinner
   ============================================ */
.spinner {
    width: 24px;
    height: 24px;
    border: 3px solid var(--border-color);
    border-top-color: var(--accent);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
}

@keyframes spin {
    to { transform: rotate(360deg); }
}

/* ============================================
   GPX Stats Panel
   ============================================ */
#gpx-stats-panel {
    position: fixed;
    bottom: 100px;
    left: 16px;
    width: 340px;
    max-width: calc(100vw - 32px);
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-lg);
    z-index: 1500;
    animation: slideUp 0.3s ease-out;
}

@keyframes slideUp {
    from {
        transform: translateY(20px);
        opacity: 0;
    }
    to {
        transform: translateY(0);
        opacity: 1;
    }
}

.gpx-stats-panel {
    padding: 20px;
}

.gpx-stats-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--border-subtle);
}

.gpx-stats-header h4 {
    margin: 0;
    font-size: 1.1em;
    font-weight: 600;
    color: var(--text-primary);
}

.gpx-close-btn {
    background: var(--bg-tertiary);
    border: none;
    color: var(--text-secondary);
    font-size: 1.5em;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
}

.gpx-close-btn:hover {
    background: var(--bg-hover);
    color: var(--text-primary);
}

#elevation-profile-container {
    margin-top: 16px;
    background: var(--bg-tertiary);
    border-radius: var(--radius-md);
    padding: 8px;
}

.elevation-chart {
    display: block;
    width: 100%;
}

/* GPX Upload Button */
.gpx-upload-wrapper {
    position: relative;
    display: inline-block;
}

.gpx-upload-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 16px;
    background: var(--bg-tertiary);
    color: var(--text-primary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    cursor: pointer;
    font-size: 0.9em;
    font-weight: 500;
    transition: all 0.2s;
}

.gpx-upload-btn:hover {
    background: var(--bg-hover);
    border-color: var(--accent);
}

.gpx-upload-btn input[type="file"] {
    position: absolute;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    cursor: pointer;
}

/* Map Controls */
.map-controls {
    position: absolute;
    top: 10px;
    right: 10px;
    z-index: 1000;
    display: flex;
    flex-direction: column;
    gap: 8px;
}

.map-control-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    color: var(--text-primary);
    cursor: pointer;
    font-size: 1.2em;
    transition: all 0.2s;
}

.map-control-btn:hover {
    background: var(--bg-tertiary);
    border-color: var(--accent);
}

.map-control-btn.active {
    background: var(--accent);
    border-color: var(--accent);
}

/* ============================================
   Radar Controls
   ============================================ */
.radar-toggle-btn {
    position: absolute;
    top: 80px;
    right: 10px;
    z-index: 1000;
    width: 40px;
    height: 40px;
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-sm);
    font-size: 1.2em;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: var(--shadow-sm);
    transition: all 0.2s;
}

.radar-toggle-btn:hover {
    background: var(--bg-tertiary);
    border-color: var(--accent);
}

.radar-toggle-btn.active {
    background: var(--accent);
    border-color: var(--accent);
}

.radar-control-panel {
    position: absolute;
    top: 130px;
    right: 10px;
    z-index: 1000;
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: 16px;
    width: 280px;
    box-shadow: var(--shadow-lg);
}

.radar-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
    font-weight: 600;
    color: var(--text-primary);
}

.radar-close-btn {
    background: none;
    border: none;
    color: var(--text-muted);
    font-size: 1.5em;
    cursor: pointer;
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    transition: all 0.2s;
}

.radar-close-btn:hover {
    background: var(--bg-tertiary);
    color: var(--text-primary);
}

.radar-timeline {
    margin-bottom: 12px;
}

.radar-time-labels {
    display: flex;
    justify-content: space-between;
    margin-bottom: 6px;
    font-size: 0.75em;
    color: var(--text-muted);
}

#radar-time-current {
    color: var(--accent);
    font-weight: 600;
}

.radar-progress-container {
    width: 100%;
    height: 6px;
    background: var(--bg-tertiary);
    border-radius: 3px;
    overflow: hidden;
}

.radar-progress {
    height: 100%;
    background: var(--accent);
    border-radius: 3px;
    transition: width 0.3s ease;
}

.radar-controls-row {
    display: flex;
    align-items: center;
    gap: 12px;
}

.radar-play-btn {
    width: 48px;
    height: 40px;
    background: var(--accent);
    border: none;
    border-radius: var(--radius-sm);
    font-size: 1.2em;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
}

.radar-play-btn:hover {
    background: var(--accent-hover);
}

.radar-settings {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 8px;
}

.radar-settings label {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.8em;
    color: var(--text-secondary);
}

.radar-settings input[type="range"] {
    flex: 1;
    height: 4px;
    -webkit-appearance: none;
    appearance: none;
    background: var(--bg-tertiary);
    border-radius: 2px;
    outline: none;
}

.radar-settings input[type="range"]::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--accent);
    cursor: pointer;
    border: 2px solid var(--bg-secondary);
}

.radar-settings select {
    flex: 1;
    padding: 4px 8px;
    background: var(--bg-tertiary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-sm);
    color: var(--text-primary);
    font-size: 0.85em;
}

/* Mobile radar adjustments */
@media (max-width: 1024px) {
    .radar-control-panel {
        width: 260px;
        right: 10px;
        top: 120px;
    }
    
    .radar-toggle-btn {
        top: 70px;
    }
}

/* Mobile GPX panel adjustments */
@media (max-width: 1024px) {
    #gpx-stats-panel {
        left: 8px;
        right: 8px;
        width: auto;
        bottom: 90px;
    }
}

